{
  "$schema": "../node_modules/@tauri-apps/cli/config.schema.json",
  "productName": "HarnessDeck",
  "version": "0.1.0",
  "identifier": "com.harnessdeck.desktop",
  "build": {
    "frontendDist": "../dist",
    "devUrl": "http://localhost:1420",
    "beforeDevCommand": "pnpm dev",
    "beforeBuildCommand": "pnpm build"
  },
  "app": {
    "windows": [
      {
        "label": "main",
        "title": "HarnessDeck",
        "titleBarStyle": "Overlay",
        "width": 1180,
        "height": 760,
        "minWidth": 1020,
        "minHeight": 680,
        "resizable": true,
        "fullscreen": false
      },
      {
        "label": "menubar",
        "title": "HarnessDeck Menu Panel",
        "url": "index.html?panel=1",
        "width": 356,
        "height": 640,
        "minWidth": 320,
        "minHeight": 540,
        "resizable": false,
        "decorations": false,
        "alwaysOnTop": true,
        "skipTaskbar": true,
        "visible": false,
        "fullscreen": false
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": ["app"],
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ],
    "android": {
      "debugApplicationIdSuffix": ".debug"
    }
  }
}
